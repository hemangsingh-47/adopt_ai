							]
						},
						"description": "**Valid Statuses:** Learning, Optimized, Paused\n**Required:** name, dailyBudget"
					},
					"response": []
				},
				{
					"name": "Update Campaign",
					"request": {
						"method": "PUT",
						"header": [],
