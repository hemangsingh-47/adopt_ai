							"mode": "raw",
							"raw": "{\n    \"name\": \"Updated Launch Name\",\n    \"dailyBudget\": 300,\n    \"status\": \"Optimized\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/campaigns/:id",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"campaigns",
								":id"
							],
							"variable": [
								{
									"key": "id",
									"value": ""
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Delete Campaign",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/campaigns/:id",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"campaigns",
								":id"
							],
							"variable": [
								{
									"key": "id",
									"value": ""
								}
							]
						}
					},
					"response": []
				}
			]
		},
